{
  "name": "June-X WhatsApp Bot",
  "description": "June-X — a feature-rich WhatsApp bot built with Baileys.",
  "logo": "https://files.catbox.moe/rpju62.jpg",
  "keywords": ["whatsapp", "bot", "baileys", "assistant"],
  "repository": "https://github.com/Vinpink2/JUNE-X",
  "stack": "container",
  "addons": [
    {
      "plan": "heroku-postgresql"
    }
  ],
  "scripts": {
    "start": "node index.js"
  },
  "env": {
    "SESSION_ID": {
      "description": "Must begin with 'JUNE-MD:~'. Generate it from the bot's pairing flow.",
      "value": "JUNE-MD:~",
      "required": true
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number in international format without the + sign (e.g. 2547XXXXXXXX).",
      "value": "254112278275",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
    }
  ]
}
